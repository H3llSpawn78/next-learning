{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "esnext"],

    "module": "esnext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",

    "skipLibCheck": true
  }
}
